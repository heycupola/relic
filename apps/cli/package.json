{
  "name": "relic",
  "version": "0.1.0",
  "description": "Manage project secrets the way you want with Relic – securely store and share them with your team.",
  "keywords": [
    "cli",
    "tui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/heycupola/relic.git",
    "directory": "apps/cli"
  },
  "author": "Can Vardar",
  "license": "MIT",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build:runner": "cd ../../packages/runner && cargo build",
    "dev": "bun run build:runner && bun run index.ts",
    "logs": "tail -f ~/Library/Application\\ Support/com.cupola.relic/relic.log",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "files": [
    "index.ts",
    "commands/**",
    "ffi/**",
    "prebuilds/**",
    "README.md"
  ],
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/bun": "latest",
    "@types/react": "^19.2.9",
    "bun-types": "^1.3.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@repo/auth": "*",
    "commander": "^13.1.0",
    "ink": "^6.6.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.4"
  }
}

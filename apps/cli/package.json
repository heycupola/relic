{
  "name": "relic",
  "version": "0.1.0",
  "description": "Manage project secrets the way you want with Relic – securely store and share them with your team.",
  "keywords": [
    "cli",
    "tui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/heycupola/relic.git",
    "directory": "apps/cli"
  },
  "author": "Can Vardar",
  "license": "MIT",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build:bindings": "cd ../../packages/cli-core && cargo build",
    "deva": "bun run build:bindings && bun run index.ts",
    "logs": "tail -f ~/Library/Application\\ Support/com.cupola.relic/relic.log",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "files": [
    "index.ts",
    "ffi/**",
    "README.md"
  ],
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/bun": "latest",
    "bun-types": "^1.3.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  }
}

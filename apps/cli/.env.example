# Convex deployment URL
CONVEX_URL=http://localhost:3210
# Web dashboard URL (used by auth for JWT endpoint)
SITE_URL=http://localhost:3000
# Set to "true" to enable dev mode
DEV=true
# Logging (via @repo/logger)
RELIC_LOG=info
RELIC_POSTHOG_KEY=
RELIC_TELEMETRY=true
RELIC_TELEMETRY_URL=https://telemetry.relic.so
# CI/CD authentication (optional - set these to skip interactive login)
# RELIC_SESSION=base64_encoded_session
# RELIC_PASSWORD=your_password

# Convex deployment URL
CONVEX_URL=http://localhost:3210
# Convex HTTP actions URL (used for API key auth)
CONVEX_SITE_URL=http://localhost:3211
# Web dashboard URL (used by auth for JWT endpoint)
SITE_URL=http://localhost:3000
# Set to "true" to enable dev mode
DEV=true
# Logging (via @repo/logger)
RELIC_LOG=info
RELIC_POSTHOG_KEY=
RELIC_TELEMETRY=true
RELIC_TELEMETRY_URL=https://telemetry.relic.so
# CI/CD (optional - set these for non-interactive API key mode)
# RELIC_API_KEY=relic_sk_...
# RELIC_PASSWORD=your_master_password
# RELIC_PROJECT_ID=your_project_id

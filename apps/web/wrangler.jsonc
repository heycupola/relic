{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "relic-web",
  "compatibility_date": "2026-03-04",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "./dist/worker-entry.js",
  "find_additional_modules": true,
  "assets": {
    "not_found_handling": "none",
    "directory": "./dist/client",
    "binding": "ASSETS"
  }
}

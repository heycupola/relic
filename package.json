{
  "name": "relic",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@emnapi/core": "^1.5.0",
    "@emnapi/wasi-threads": "^1.1.0",
    "@napi-rs/wasm-runtime": "^1.0.5",
    "@tybys/wasm-util": "^0.10.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.21",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "!packages/telemetry-proxy"
    ],
    "catalog": {
      "autumn-js": "^0.1.40",
      "@convex-dev/better-auth": "^0.8.9",
      "better-auth": "1.3.8",
      "convex": "^1.27.3",
      "convex-helpers": "^0.1.104",
      "@tailwindcss/postcss": "^4.1.14",
      "postcss": "^8.5.6",
      "tailwindcss": "^4.1.14",
      "tw-animate-css": "^1.4.0",
      "@biomejs/biome": "^2.2.5",
      "open": "^11.0.0",
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}

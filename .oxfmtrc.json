{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "singleAttributePerLine": false,
  "ignorePatterns": [
    "**/node_modules",
    "**/dist",
    "**/.next",
    "**/build",
    "**/.turbo",
    "**/rust/target",
    "**/rust/prebuilt",
    "**/_generated",
    "**/*.mdx"
  ]
}

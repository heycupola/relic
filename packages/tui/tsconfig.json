{
  "extends": "@repo/typescript-config/bundler.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@repo/backend": ["../backend/index.ts"],
      "@repo/backend/*": ["../backend/*"],
      "@repo/auth": ["../auth/index.ts"],
      "@repo/auth/*": ["../auth/*"],
      "@repo/crypto": ["../crypto/index.ts"],
      "@repo/crypto/*": ["../crypto/*"],
      "@repo/logger": ["../logger/index.ts"],
      "@repo/logger/*": ["../logger/*"]
    },
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsxImportSource": "@opentui/react"
  },
  "include": ["./**/*.ts", "./**/*.tsx"],
  "exclude": ["node_modules", "../backend/convex/lib/emails"]
}

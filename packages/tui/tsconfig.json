{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@repo/backend": ["../backend/index.ts"],
      "@repo/backend/*": ["../backend/*"]
    },
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "strict": true,
    "skipLibCheck": true
  }
}

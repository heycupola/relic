# ============================================
# Convex Dashboard Environment Variables
# Set these in your Convex deployment dashboard
# ============================================

# App
SITE_URL=http://localhost:3000
ENVIRONMENT=development

# Auth (better-auth)
BETTER_AUTH_SECRET=

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (email)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
FROM_EMAIL_ADDRESS=

# Autumn (billing)
AUTUMN_SECRET_KEY=
AUTUMN_WEBHOOK_SECRET=

# ============================================
# CLI Environment Variables
# Used by Convex CLI for local development
# ============================================
CONVEX_SITE_URL=https://your-deployment.convex.site

# ============================================
# CI/CD Deploy Key
# Used by `convex deploy` in CI pipelines
# Get this from Convex dashboard -> Settings -> Deploy Key
# ============================================
# CONVEX_DEPLOY_KEY=

# ============================================
# Optional
# ============================================
# LOG_LEVEL=debug
